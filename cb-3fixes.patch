+    /** /cb recolor &lt;id&gt; &lt;color|hex&gt; — recolor one block in place, with undo. */
+    private static int cmdRecolor(ServerCommandSource src, String rawId, String colorRaw) {
+        ServerPlayerEntity player = src.getPlayer();
+        if (player == null) { ChatHelper.error(src, ChatHelper.formattedKey("cmd.console_player_only")); return 0; }
+        String id = sanitize(rawId);
+        if (!SlotManager.hasId(id)) { src.sendMessage(notFound(id)); return 0; }
+        String c = colorRaw.trim();
+        Integer rgb = null;
+        String label = c;
+        // 1) named color from the library (e.g. "Red", "Sky Blue")
+        for (ColorLibrary.LibColor lc : ColorLibrary.ALL) {
+            if (lc.name().equalsIgnoreCase(c)) { rgb = lc.rgb(); label = lc.name(); break; }
+        }
+        // 2) hex (#RRGGBB or RRGGBB)
+        if (rgb == null) {
+            String norm = PlayerPaletteManager.normalize(c);
+            if (norm != null) {
+                try { rgb = Integer.parseInt(norm.replace("#", ""), 16); label = norm.toUpperCase(java.util.Locale.ROOT); }
+                catch (NumberFormatException ignored) {}
+            }
+        }
+        if (rgb == null) {
+            ChatHelper.error(src, "§cUnknown color '§f" + c + "§c'. Use a name (e.g. §fRed§c) or hex (e.g. §fFF5500§c). Browse with §f/cb colors§c.");
+            return 0;
+        }
+        int r = (rgb >> 16) & 0xFF, g = (rgb >> 8) & 0xFF, b = rgb & 0xFF;
+        GuiManager.applySingleRecolor(player, id, r, g, b, label);
+        return 1;
+    }
