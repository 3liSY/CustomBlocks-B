+    private static void handleSingleBlockPickerClick(ServerPlayerEntity player, GuiState state, int slot) {
+        UUID uuid = player.getUuid();
+        String action = state.editingId();
+        int page = state.page();
+        List<SlotData> blocks = sortedBlocks();
+        int total = blocks.size();
+        int maxPage = total == 0 ? 0 : Math.max(0, (total - 1) / BLOCKS_PER_PAGE);
+
+        if (slot == 0) { handleEscBack(player); return; }
+        if (slot == 45 && page > 0) {
+            STATES.put(uuid, GuiState.singlePick(action, page - 1));
+            refreshScreen(player, buildSingleBlockPicker(uuid, action, page - 1));
+            return;
+        }
+        if (slot == 53 && page < maxPage) {
+            STATES.put(uuid, GuiState.singlePick(action, page + 1));
+            refreshScreen(player, buildSingleBlockPicker(uuid, action, page + 1));
+            return;
+        }
+        if (slot >= 18 && slot <= 35) {
+            int idx = page * BLOCKS_PER_PAGE + (slot - 18);
+            if (idx < blocks.size()) {
+                String id = blocks.get(idx).customId;
+                if ("reid".equals(action)) {
+                    openShortInputPrompt(player,
+                        new PendingInput(InputAction.REID_TEXT, id, null, null, null, page),
+                        "§eNew ID for " + id, new ItemStack(Items.NAME_TAG), id);
+                } else {
+                    pushBackStack(uuid);
+                    openColorPicker(player, id);
+                }
+            }
+        }
+    }
