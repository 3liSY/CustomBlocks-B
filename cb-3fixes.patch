+    private static java.util.List<SlotData> filteredBulkPool(UUID uuid) {
+        String catFilt = BULK_OP_CAT_FILTER.get(uuid);
+        java.util.List<SlotData> pool = catFilt != null
+                ? new java.util.ArrayList<>(com.customblocks.core.CategoryManager.getBlocksInCategory(catFilt))
+                : new java.util.ArrayList<>(sortedBlocks());
+        String q = BULK_OP_SEARCH.get(uuid);
+        if (q != null && !q.isBlank()) {
+            String ql = q.toLowerCase(java.util.Locale.ROOT);
+            pool.removeIf(d -> !(d.customId.toLowerCase(java.util.Locale.ROOT).contains(ql)
+                    || (d.displayName != null && d.displayName.toLowerCase(java.util.Locale.ROOT).contains(ql))));
+        }
+        String flag = BULK_OP_FLAG_FILTER.get(uuid);
+        if (flag != null && !flag.isEmpty()) {
+            switch (flag) {
+                case "fav"      -> pool.removeIf(d -> !com.customblocks.core.FavoritesManager.isFavorite(uuid, d.customId));
+                case "locked"   -> pool.removeIf(d -> !com.customblocks.core.LockManager.isLocked(d.customId));
+                case "letters"  -> pool.removeIf(d -> !d.isLetter);
+                case "animated" -> pool.removeIf(d -> d.animMeta == null);
+                default -> {}
+            }
+        }
+        return pool;
+    }
